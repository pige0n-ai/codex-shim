{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codex-Shim GUI",
  "version": "0.1.0",
  "identifier": "ai.pige0n.codex-shim-gui",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Codex-Shim",
        "width": 1440,
        "height": 980,
        "minWidth": 1100,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
